# Environment Configuration

# C# NetSDK Bridge Service URL
NETSDK_BRIDGE_URL=http://localhost:5000

# Server IP for Auto Registration (used by NetSDKBridge)
# 0.0.0.0 = listen on ALL interfaces (localhost + LAN + public)
SERVER_IP=0.0.0.0

# Express Server Port
PORT=3001

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000

# Logging
LOG_LEVEL=info
